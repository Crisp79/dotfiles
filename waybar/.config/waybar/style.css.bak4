@import 'colors.css';

*{
    font-family: JetbrainsMono Nerd Font;
  font-size: 10px;
  min-height: 0;
  padding-right: 2px;
  padding-left: 2px;
  padding-bottom: 0px;
}

window#waybar
.modules-center{
    background-color: @bg1;
    padding: 2px 12px;
    border-radius: 20px;
}

#clock{
    font-weight: 600;
}

#workspaces {
    font-size:20px;
}

#workspaces button{ 
    color: @fg;
}
#workspaces button.empty{
    color: @grey0;
}
#workspaces button.active{
    color: @red2;
}
